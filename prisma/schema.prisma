generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  username String @unique
  password String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  /**
   * 1:1 relation
   * One user can have many posts
   */
  posts Post[]

  // One user can like many posts
  likes Like[]

  /**
   * Self-relation
   * Users who follow this user
   */
  followers Follow[] @relation("following")

  // Users this user is following
  following Follow[] @relation("follower")
}

model Post {
  id      Int    @id @default(autoincrement())
  title   String
  content String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Stores the ID of the author (User)
  authorId Int

  /**
   * Relation to User
   * fields: [authorId] - is a foreign key
   * references: [id]   - references User.id
   * onDelete: Cascade  - delete posts if user is deleted
   */
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  /**
   * Number of likes for this post
   * This is a denormalized field to improve performance
   */
  likesCount Int @default(0)

  /**
   * One to many relation
   * A post can have many likes
   */
  likes Like[]

  /**
   * Database index on authorId
   * Improves performance
   */
  @@index([authorId])
}

model Follow {
  id Int @id @default(autoincrement())

  // Timestamp
  createdAt DateTime @default(now())

  // Id of the user who is following
  followerId Int

  /**
   * Relation to User (the follower)
   * "follower" is the relation name
   * needed because User is referenced twice
   */
  follower User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)

  // Id of the user being followed
  followingId Int

  // Relation to User (the followed user)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  // Ensures a user can follow another user only once
  @@unique([followerId, followingId])
  // Index to improve performance
  // "who am i following?"
  @@index([followerId])
  // "who follows this user?"
  @@index([followingId])
}

model Like {
  id Int @id @default(autoincrement())

  // Timestamp
  createdAt DateTime @default(now())

  // Relations
  // Id of the user who liked the post
  userId Int

  /**
   * Relation to User
   * fields: [userId] - is a foreign key
   * references: [id] - references Post.id
   * onDelete: Cascade - delete likes if user is deleted
   */
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Id of the liked post
  postId Int

  /**
   * Relation to Post
   * fields: [postId] - is a foreign key
   * references: [id] - references User.id
   * onDelete: Cascade - delete likes if post is deleted
   */
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Index to improve performance

  // User can like a post only once
  @@unique([userId, postId])
  // "how many likes does this post have?"
  @@index([postId])
  // "what posts did this user likes?"
  @@index([userId])
}
