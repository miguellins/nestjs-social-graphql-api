generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                @id @default(autoincrement())
  name                    String
  email                   String             @unique
  username                String             @unique
  password                String
  role                    UserRole           @default(USER)
  privacySetting          UserPrivacySetting @default(PUBLIC)
  accountState            AccountState       @default(ACTIVE)
  accountStateReason      String?
  accountStateChangedAt   DateTime?
  accountStateChangedById Int?
  isEmailVerified         Boolean            @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * 1:N relation
   * One user can have many posts
   */
  posts Post[]

  /**
   * 1:N relation
   * One user can create many comments
   */
  comments Comment[]

  /**
   * One-to-many relation
   * A user can be mentioned in many posts
   */
  postMentions PostMention[] @relation("UserPostMentions")

  /**
   * One-to-many relation
   * A user can be mentioned in many comments
   */
  commentMentions CommentMention[] @relation("UserCommentMentions")

  // One user can like many posts
  likes Like[]

  /**
   * One user can bookmark many posts
   */
  bookmarks Bookmark[]

  /**
   * Self-relation
   * Users who follow this user
   */
  followers Follow[] @relation("following")

  // Users this user is following
  following Follow[] @relation("follower")

  /**
   * Self-relation
   * Follow requests sent by this user
   */
  followRequestsSent FollowRequest[] @relation("FollowRequestRequester")

  /**
   * Self-relation
   * Follow requests received by this user
   */
  followRequestsReceived FollowRequest[] @relation("FollowRequestTarget")

  /**
   * 1:N relation
   * Block relationships created by this user
   */
  blocksInitiated UserBlock[] @relation("UserBlockBlocker")

  /**
   * 1:N relation
   * Block relationships targeting this user
   */
  blocksReceived UserBlock[] @relation("UserBlockBlocked")

  /**
   * 1:N relation
   * Content reports submitted by this user
   */
  reportsSubmitted ContentReport[]

  /**
   * 1:N relation
   * Notifications sent by this user (as the actor who triggered the event)
   */
  sentNotifications Notification[] @relation("NotificationActor")

  /**
   * 1:N relation
   * Notifications received by this user (as the target of the event)
   */
  receivedNotifications Notification[] @relation("NotificationRecipient")

  /**
   * 1:N relation
   * Password reset tokens issued for this user
   */
  passwordResetTokens PasswordResetToken[]

  /**
   * 1:N relation
   * Refresh sessions issued for this user
   */
  refreshSessions RefreshSession[]

  /**
   * 1:N relation
   * Email verification tokens issued for this user
   */
  emailVerificationTokens EmailVerificationToken[]

  /**
   * 1:N relation
   * Moderation actions performed by this user
   */
  moderationActions ModerationAction[]

  /**
   * 1:N relation
   * Media uploaded and owned by this user
   */
  media Media[]

  /**
   * Compound index on createdAt + id descending
   * Improves cursor-pagination queries for the public users list
   * ordered by newest first with deterministic id tie-breaking.
   */
  @@index([createdAt(sort: Desc), id(sort: Desc)])
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum UserPrivacySetting {
  PUBLIC
  PRIVATE
}

enum AccountState {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model Post {
  id      Int     @id @default(autoincrement())
  title   String?
  content String

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  editedAt  DateTime?
  removedAt DateTime?

  // Stores the ID of the author (User)
  authorId Int

  /**
   * Optional moderator/admin actor who removed this post
   * Stored as an id only because the public API never exposes it directly.
   */
  removedById Int?

  /**
   * Moderator/admin reason for removing this post from normal reads
   */
  removalReason String?

  /**
   * Relation to User
   * fields: [authorId] - this model stores the foreign key
   * references: [id]   - references User.id
   * onDelete: Cascade  - delete posts if the author is deleted
   */
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  /**
   * Number of likes for this post
   * This is a denormalized field to improve read performance
   */
  likesCount Int @default(0)

  /**
   * Number of comments for this post
   * This is a denormalized field to improve read performance
   */
  commentsCount Int @default(0)

  /**
   * Number of times this post was viewed
   * For now, a view is counted when postById is called successfully
   */
  viewsCount Int @default(0)

  /**
   * One-to-many relation
   * A post can have many likes
   */
  likes Like[]

  /**
   * One-to-many relation
   * A post can have many bookmarks
   */
  bookmarks Bookmark[]

  /**
   * One-to-many relation
   * A post can have many comments
   */
  comments Comment[]

  /**
   * One-to-many relation
   * A post can have many content reports
   */
  reports ContentReport[]

  /**
   * One-to-many relation
   * A post can have many media attachments via the join table
   */
  mediaAttachments PostMedia[]

  /**
   * One-to-many relation
   * A post can mention many users via durable mention rows
   */
  mentions PostMention[] @relation("PostMentions")

  /**
   * One-to-many relation
   * A post can have many moderation actions targeting it
   */
  moderationActions ModerationAction[] @relation("ModerationActionPost")

  /**
   * Database index on authorId
   * Improves queries like:
   * - "get all posts from one author"
   * - feed filtering by followed authors
   */
  @@index([authorId])
  /**
   * Database index on createdAt descending
   * Improves queries that sort by newest posts first
   */
  @@index([createdAt(sort: Desc)])
  /**
   * Compound index on authorId + createdAt descending
   * Improves feed queries like:
   * - "get posts from these authors"
   * - ordered by newest first
   */
  @@index([authorId, createdAt(sort: Desc)])
  /**
   * Compound index on createdAt + id descending
   * Improves cursor-pagination queries for public post timelines
   * ordered by newest first with deterministic id tie-breaking.
   */
  @@index([createdAt(sort: Desc), id(sort: Desc)])
  /**
   * Compound index on authorId + createdAt + id descending
   * Improves author-scoped timelines with cursor-pagination tie-breaking.
   */
  @@index([authorId, createdAt(sort: Desc), id(sort: Desc)])
  /**
   * Compound index on removedAt + createdAt + id descending
   * Supports normal read paths that exclude moderated content while keeping
   * chronological ordering deterministic.
   */
  @@index([removedAt, createdAt(sort: Desc), id(sort: Desc)])
}

model Comment {
  id      Int    @id @default(autoincrement())
  content String

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  removedAt DateTime?

  // Stores the ID of the author (User)
  authorId Int

  /**
   * Optional moderator/admin actor who removed this comment
   * Stored as an id only because the public API never exposes it directly.
   */
  removedById Int?

  /**
   * Moderator/admin reason for removing this comment from normal reads
   */
  removalReason String?

  /**
   * Relation to User
   * fields: [authorId] - this model stores the foreign key
   * references: [id]   - references User.id
   * onDelete: Cascade  - delete comments if the author is deleted
   */
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Stores the ID of the related post
  postId Int

  /**
   * Relation to Post
   * fields: [postId]   - this model stores the foreign key
   * references: [id]   - references Post.id
   * onDelete: Cascade  - delete comments if the post is deleted
   */
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  /**
   * Optional parent comment id used to model one-level comment replies.
   * Null means this is a top-level comment.
   */
  parentCommentId Int?

  /**
   * Optional parent comment relation for one-level comment threading.
   */
  parentComment Comment? @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)

  /**
   * Direct replies to this comment in the one-level thread model.
   */
  replies Comment[] @relation("CommentReplies")

  /**
   * One-to-many relation
   * A comment can have many content reports
   */
  reports ContentReport[]

  /**
   * One-to-many relation
   * A comment can have many moderation actions targeting it
   */
  moderationActions ModerationAction[] @relation("ModerationActionComment")

  /**
   * One-to-many relation
   * A comment can mention many users via durable mention rows
   */
  mentions CommentMention[] @relation("CommentMentions")

  /**
   * Database index on authorId
   * Improves queries like:
   * - "get all comments created by one user"
   */
  @@index([authorId])
  /**
   * Database index on postId
   * Improves queries like:
   * - "get all comments for one post"
   */
  @@index([postId])
  /**
   * Database index on createdAt descending
   * Improves queries that sort comments by newest first
   */
  @@index([createdAt(sort: Desc)])
  /**
   * Compound index on postId + createdAt descending
   * Improves queries like:
   * - "get all comments for a post"
   * - ordered by newest first
   */
  @@index([postId, createdAt(sort: Desc)])
  /**
   * Compound index on postId + createdAt + id descending
   * Improves cursor-pagination for post comments with deterministic id tie-breaking.
   */
  @@index([postId, createdAt(sort: Desc), id(sort: Desc)])
  /**
   * Compound index on postId + removedAt + createdAt + id descending
   * Supports post-scoped comment reads that hide moderated comments.
   */
  @@index([postId, removedAt, createdAt(sort: Desc), id(sort: Desc)])
  /**
   * Compound index on postId + parentCommentId + removedAt + createdAt + id descending
   * Supports top-level threaded comment reads with deterministic ordering.
   */
  @@index([postId, parentCommentId, removedAt, createdAt(sort: Desc), id(sort: Desc)])
  /**
   * Compound index on parentCommentId + removedAt + createdAt + id descending
   * Supports bounded reply reads for one comment thread.
   */
  @@index([parentCommentId, removedAt, createdAt(sort: Desc), id(sort: Desc)])
}

enum ModerationActionType {
  REMOVE_POST
  REMOVE_COMMENT
  SUSPEND_USER
  REACTIVATE_USER
}

enum ModerationTargetType {
  POST
  COMMENT
  USER
}

model ModerationAction {
  id Int @id @default(autoincrement())

  actorId    Int
  actionType ModerationActionType
  targetType ModerationTargetType
  targetId   Int
  reason     String
  reportId   Int?
  postId     Int?
  commentId  Int?

  createdAt DateTime @default(now())

  /**
   * Relation to User
   * fields: [actorId] - the moderator/admin who performed the action
   * references: [id]  - references User.id
   * onDelete: Cascade - delete action logs if the actor is deleted
   */
  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  /**
   * Optional relation to a linked reviewed report
   */
  report ContentReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  /**
   * Optional relation to the targeted post
   */
  post Post? @relation("ModerationActionPost", fields: [postId], references: [id], onDelete: SetNull)

  /**
   * Optional relation to the targeted comment
   */
  comment Comment? @relation("ModerationActionComment", fields: [commentId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt(sort: Desc)])
  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([reportId])
  @@index([postId])
  @@index([commentId])
}

model Follow {
  id Int @id @default(autoincrement())

  // Timestamp
  createdAt DateTime @default(now())

  // Id of the user who is following
  followerId Int

  /**
   * Relation to User (the follower)
   * "follower" is the relation name
   * needed because User is referenced twice
   */
  follower User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)

  // Id of the user being followed
  followingId Int

  // Relation to User (the followed user)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  // Ensures a user can follow another user only once
  @@unique([followerId, followingId])
  // Index to improve performance
  // "who am i following?"
  @@index([followerId])
  // "who follows this user?"
  @@index([followingId])
  // Improves public follow-list cursor pagination ordered by newest first
  @@index([createdAt(sort: Desc), id(sort: Desc)])
}

enum FollowRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

model FollowRequest {
  id Int @id @default(autoincrement())

  // Id of the user who sent the follow request
  requesterId Int

  // Id of the private-account user who received the follow request
  targetUserId Int

  /**
   * Current workflow state for the follow request
   * Defaults to pending until the target user approves, rejects, or the requester cancels
   */
  status FollowRequestStatus @default(PENDING)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * Relation to User (the requester)
   * "FollowRequestRequester" is the relation name
   * needed because User is referenced twice
   */
  requester User @relation("FollowRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  /**
   * Relation to User (the target user)
   * "FollowRequestTarget" is the relation name
   * needed because User is referenced twice
   */
  targetUser User @relation("FollowRequestTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  // Ensures only one active request record exists per requester-target pair
  @@unique([requesterId, targetUserId])
  /**
   * Improves inbox-style queries for requests received by a target user
   * filtered by status and ordered by newest first with deterministic id tie-breaking
   */
  @@index([targetUserId, status, createdAt(sort: Desc), id(sort: Desc)])
  /**
   * Improves sent-request queries for a requester
   * filtered by status and ordered by newest first with deterministic id tie-breaking
   */
  @@index([requesterId, status, createdAt(sort: Desc), id(sort: Desc)])
}

model UserBlock {
  id Int @id @default(autoincrement())

  // Timestamp
  createdAt DateTime @default(now())

  // Id of the user creating the block
  blockerId Int

  /**
   * Relation to User (the blocker)
   * "UserBlockBlocker" is the relation name
   * needed because User is referenced twice
   */
  blocker User @relation("UserBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)

  // Id of the blocked user
  blockedId Int

  /**
   * Relation to User (the blocked user)
   * "UserBlockBlocked" is the relation name
   * needed because User is referenced twice
   */
  blocked User @relation("UserBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([blockedId])
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE
  SEXUAL_CONTENT
  VIOLENCE
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  OPEN
  DISMISSED
  ACTIONED
}

model ContentReport {
  id Int @id @default(autoincrement())

  /**
   * Stores the reporting user.
   * Application-level invariant for V1:
   * - exactly one of postId or commentId must be set
   * Prisma schema cannot express that CHECK constraint directly,
   * so migration generation/review is still required if you want
   * the database to enforce it beyond the service layer.
   */
  reporterId Int
  postId     Int?
  commentId  Int?

  reason  ReportReason
  details String?
  status  ReportStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * Relation to User
   * fields: [reporterId] - this model stores the foreign key
   * references: [id]     - references User.id
   * onDelete: Cascade    - delete reports if reporter is deleted
   */
  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  /**
   * Relation to Post
   * fields: [postId]     - nullable post target
   * references: [id]     - references Post.id
   * onDelete: Cascade    - delete reports if reported post is deleted
   */
  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  /**
   * Relation to Comment
   * fields: [commentId]  - nullable comment target
   * references: [id]     - references Comment.id
   * onDelete: Cascade    - delete reports if reported comment is deleted
   */
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  /**
   * One-to-many relation
   * A report can be linked to later moderation actions
   */
  moderationActions ModerationAction[]

  /**
   * Compound index on reporterId + postId + status
   * Improves duplicate-open checks for post reports without enforcing
   * uniqueness across all final statuses.
   */
  @@index([reporterId, postId, status])
  /**
   * Compound index on reporterId + commentId + status
   * Improves duplicate-open checks for comment reports without enforcing
   * uniqueness across all final statuses.
   */
  @@index([reporterId, commentId, status])
  /**
   * Compound index on reporterId + createdAt + id descending
   * Improves moderation-history queries scoped to one reporter
   * with deterministic newest-first ordering.
   */
  @@index([reporterId, createdAt(sort: Desc), id(sort: Desc)])
  /**
   * Database index on postId
   * Improves review queries for reports attached to one post.
   */
  @@index([postId])
  /**
   * Database index on commentId
   * Improves review queries for reports attached to one comment.
   */
  @@index([commentId])
  /**
   * Compound index on status + createdAt descending
   * Improves moderation queue queries filtered by report status
   * and ordered by newest reports first.
   */
  @@index([status, createdAt(sort: Desc)])
}

model Like {
  id Int @id @default(autoincrement())

  // Timestamp
  createdAt DateTime @default(now())

  // Relations
  // Id of the user who liked the post
  userId Int

  /**
   * Relation to User
   * fields: [userId] - is a foreign key
   * references: [id] - references User.id
   * onDelete: Cascade - delete likes if user is deleted
   */
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Id of the liked post
  postId Int

  /**
   * Relation to Post
   * fields: [postId] - is a foreign key
   * references: [id] - references Post.id
   * onDelete: Cascade - delete likes if post is deleted
   */
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Index to improve performance

  // User can like a post only once
  @@unique([userId, postId])
  // "how many likes does this post have?"
  @@index([postId])
  // "what posts did this user likes?"
  @@index([userId])
  // Improves public like-list cursor pagination ordered by newest first
  @@index([createdAt(sort: Desc), id(sort: Desc)])
  // Improves post-scoped like cursor pagination with deterministic tie-breaking
  @@index([postId, createdAt(sort: Desc), id(sort: Desc)])
  // Improves user-scoped like cursor pagination with deterministic tie-breaking
  @@index([userId, createdAt(sort: Desc), id(sort: Desc)])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  userId    Int
  postId    Int

  /**
   * Relation to User
   * fields: [userId] - this model stores the bookmarking user foreign key
   * references: [id] - references User.id
   * onDelete: Cascade - delete bookmarks if the user is deleted
   */
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /**
   * Relation to Post
   * fields: [postId] - this model stores the bookmarked post foreign key
   * references: [id] - references Post.id
   * onDelete: Cascade - delete bookmarks if the post is deleted
   */
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([postId])
}

model PostMention {
  id Int @id @default(autoincrement())

  postId          Int
  mentionedUserId Int
  createdAt       DateTime @default(now())

  /**
   * Relation to the post that contains the mention
   */
  post Post @relation("PostMentions", fields: [postId], references: [id], onDelete: Cascade)

  /**
   * Relation to the user mentioned in the post
   */
  mentionedUser User @relation("UserPostMentions", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([postId, mentionedUserId])
  @@index([mentionedUserId])
  @@index([postId])
}

model CommentMention {
  id Int @id @default(autoincrement())

  commentId       Int
  mentionedUserId Int
  createdAt       DateTime @default(now())

  /**
   * Relation to the comment that contains the mention
   */
  comment Comment @relation("CommentMentions", fields: [commentId], references: [id], onDelete: Cascade)

  /**
   * Relation to the user mentioned in the comment
   */
  mentionedUser User @relation("UserCommentMentions", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId])
  @@index([mentionedUserId])
  @@index([commentId])
}

enum NotificationType {
  USER_FOLLOWED
  POST_LIKED
  COMMENT_REPLIED
  POST_MENTIONED
  COMMENT_MENTIONED
}

model Notification {
  id Int @id @default(autoincrement())

  // Type of notification event (e.g. USER_FOLLOWED, POST_LIKED)
  type NotificationType

  // Short heading displayed in the notification
  title String

  // Optional longer description of the notification
  body String?

  // Whether the recipient has read this notification
  isRead Boolean @default(false)

  // Timestamp of when the notification was read; null if unread
  readAt DateTime?

  /**
   * Optional reference to the entity that triggered the notification
   * e.g. the Post.id for a POST_LIKED event
   */
  entityId Int?

  // Id of the user who triggered the notification (e.g. the follower, the liker)
  actorId Int

  // Id of the user who receives the notification
  recipientId Int

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * Relation to User (the actor)
   * fields: [actorId] - is a foreign key
   * references: [id]  - references User.id
   * onDelete: Cascade - delete notifications if actor is deleted
   */
  actor User @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  /**
   * Relation to User (the recipient)
   * fields: [recipientId] - is a foreign key
   * references: [id]      - references User.id
   * onDelete: Cascade     - delete notifications if recipient is deleted
   */
  recipient User @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  /**
   * Compound index on recipientId, isRead, and createdAt
   * Optimizes the common query: "fetch unread notifications for a user, ordered by date"
   */
  @@index([recipientId, isRead, createdAt])
  /**
   * Compound index on recipientId, createdAt, and id descending
   * Improves notification timeline pagination for one recipient ordered by newest first.
   */
  @@index([recipientId, createdAt(sort: Desc), id(sort: Desc)])
  /**
   * Compound index on recipientId, isRead, createdAt, and id descending
   * Improves unread/read-filtered notification pagination with deterministic tie-breaking.
   */
  @@index([recipientId, isRead, createdAt(sort: Desc), id(sort: Desc)])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  /**
   * Relation to User
   * fields: [userId] - is a foreign key
   * references: [id] - references User.id
   * onDelete: Cascade - delete reset tokens if user is deleted
   */
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /**
   * Database index on userId
   * Improves queries like:
   * - "delete all password reset tokens for one user"
   * - "list reset tokens issued for one user"
   */
  @@index([userId])
  /**
   * Database index on expiresAt
   * Improves cleanup and expiry checks for password reset tokens
   */
  @@index([expiresAt])
}

model RefreshSession {
  id                  Int       @id @default(autoincrement())
  userId              Int
  tokenHash           String    @unique
  expiresAt           DateTime
  lastUsedAt          DateTime  @default(now())
  revokedAt           DateTime?
  replacedBySessionId Int?
  userAgent           String?
  ipAddress           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  /**
   * Relation to User
   * fields: [userId] - is a foreign key
   * references: [id] - references User.id
   * onDelete: Cascade - delete refresh sessions if user is deleted
   */
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /**
   * Database index on userId
   * Improves queries like:
   * - "list all refresh sessions for one user"
   */
  @@index([userId])
  /**
   * Database index on expiresAt
   * Improves cleanup and expiry checks for refresh sessions
   */
  @@index([expiresAt])
  /**
   * Database index on revokedAt
   * Improves queries that check active vs revoked refresh sessions
   */
  @@index([revokedAt])
  /**
   * Compound index on userId, revokedAt, and expiresAt
   * Improves user-scoped session reads filtered by active/revoked state and expiry
   */
  @@index([userId, revokedAt, expiresAt])
}

model EmailVerificationToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  /**
   * Relation to User
   * fields: [userId] - is a foreign key
   * references: [id] - references User.id
   * onDelete: Cascade - delete verification tokens if user is deleted
   */
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /**
   * Database index on userId
   * Improves queries like:
   * - "list all verification tokens for one user"
   */
  @@index([userId])
  /**
   * Database index on expiresAt
   * Improves cleanup and expiry checks for verification tokens
   */
  @@index([expiresAt])
  /**
   * Database index on usedAt
   * Improves queries that check active vs consumed verification tokens
   */
  @@index([usedAt])
  /**
   * Compound index on userId, usedAt, and expiresAt
   * Improves user-scoped verification token reads filtered by active/used state and expiry
   */
  @@index([userId, usedAt, expiresAt])
}

enum MediaKind {
  POST_IMAGE
  POST_VIDEO
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaStatus {
  PENDING_UPLOAD
  READY
}

enum MediaVisibility {
  PUBLIC
}

enum StorageProvider {
  R2
}

model Media {
  id               Int             @id @default(autoincrement())
  ownerId          Int
  kind             MediaKind
  type             MediaType
  status           MediaStatus
  visibility       MediaVisibility
  storageProvider  StorageProvider
  bucket           String
  objectKey        String          @unique
  originalFileName String?
  mimeType         String
  bytes            Int?
  etag             String?
  width            Int?
  height           Int?
  durationMs       Int?
  expiresAt        DateTime?
  attachedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  /**
   * Relation to User
   * fields: [ownerId] - stores the uploader/owner foreign key
   * references: [id]  - references User.id
   * onDelete: Cascade - delete media if the owning user is deleted
   */
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  /**
   * One-to-many relation
   * A media item can be attached to posts through the join table
   */
  postAttachments PostMedia[]

  /**
   * Compound index on ownerId + createdAt descending
   * Improves owner-scoped media reads ordered by newest first.
   */
  @@index([ownerId, createdAt(sort: Desc)])
  /**
   * Compound index on ownerId + createdAt + id descending
   * Improves cursor-pagination for owner-scoped media lists with deterministic tie-breaking.
   */
  @@index([ownerId, createdAt(sort: Desc), id(sort: Desc)])
  /**
   * Compound index on status + expiresAt
   * Improves cleanup and lookup of pending or expired media uploads.
   */
  @@index([status, expiresAt])
  /**
   * Compound index on type + status
   * Improves media validation and attachment-rule queries filtered by type and lifecycle status.
   */
  @@index([type, status])
}

model PostMedia {
  id        Int      @id @default(autoincrement())
  postId    Int
  mediaId   Int
  sortOrder Int
  createdAt DateTime @default(now())

  /**
   * Relation to Post
   * fields: [postId] - stores the parent post foreign key
   * references: [id] - references Post.id
   * onDelete: Cascade - delete only relation rows when the post is deleted
   */
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  /**
   * Relation to Media
   * fields: [mediaId] - stores the attached media foreign key
   * references: [id]  - references Media.id
   * onDelete: Cascade - remove relation rows if media is deleted later
   */
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaId])
  @@unique([postId, sortOrder])
  /**
   * Database index on postId
   * Improves queries like:
   * - "load all media attachments for one post"
   */
  @@index([postId])
  /**
   * Database index on mediaId
   * Improves queries like:
   * - "find post attachments for one media item"
   */
  @@index([mediaId])
}
