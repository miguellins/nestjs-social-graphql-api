        {
          "expr": "rate(feed_projection_purge_errors_total{process=\"worker\"}[5m])",
          "legendFormat": "purge errors",
          "refId": "B"
        },
        {
          "expr": "sum by (event_type) (rate(outbox_events_total{process=\"worker\",event_type=~\"feed\\\\.home\\\\..+\"}[5m]))",
          "legendFormat": "{{event_type}}",
          "refId": "C"
        }
      ],
      "title": "Feed Projection Maintenance",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
