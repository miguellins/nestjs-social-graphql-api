    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "outbox_pending_count{process=\"worker\"}",
          "legendFormat": "pending",
          "refId": "A"
        },
        {
          "expr": "outbox_failed_count{process=\"worker\"}",
          "legendFormat": "failed",
          "refId": "B"
        },
        {
          "expr": "outbox_processing_count{process=\"worker\"}",
          "legendFormat": "processing",
          "refId": "C"
        }
      ],
      "title": "Outbox Backlog",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "outbox_oldest_pending_age_seconds{process=\"worker\"}",
          "legendFormat": "oldest pending",
          "refId": "A"
        },
        {
          "expr": "outbox_oldest_processing_age_seconds{process=\"worker\"}",
          "legendFormat": "oldest processing",
          "refId": "B"
        }
      ],
      "title": "Outbox Lag",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (outcome) (rate(outbox_events_total{process=\"worker\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Outbox Event Outcomes",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, event_type) (rate(outbox_event_processing_seconds_bucket{process=\"worker\"}[5m])))",
          "legendFormat": "p50 {{event_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, event_type) (rate(outbox_event_processing_seconds_bucket{process=\"worker\"}[5m])))",
          "legendFormat": "p95 {{event_type}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, event_type) (rate(outbox_event_processing_seconds_bucket{process=\"worker\"}[5m])))",
          "legendFormat": "p99 {{event_type}}",
          "refId": "C"
        }
      ],
      "title": "Outbox Processing Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
