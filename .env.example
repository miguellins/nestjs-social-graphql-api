# Docker/Compose defaults (safe for local dev only)
NODE_ENV=development

# App
API_PORT=3000
PORT=3000

# Database (Compose uses mysql service name internally)
MYSQL_PORT=3308
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=mydb
DATABASE_URL=mysql://root:root@mysql:3306/mydb

# Redis (Compose uses redis service name internally)
REDIS_PORT=6380
REDIS_URL=redis://redis:6379
GRAPHQL_SUBSCRIPTIONS_REDIS_URL=redis://redis:6379
GRAPHQL_SUBSCRIPTIONS_REDIS_NAMESPACE=graphql-subscriptions

# REQUIRED by env schema (use real secrets outside local dev)
JWT_SECRET=dev-only-change-me
PASSWORD_PEPPER=dev-only-change-me

# Optional: metrics/tracing (disabled by default)
METRICS_ENABLED=false
METRICS_HOST=0.0.0.0
METRICS_PORT=9090
WORKER_METRICS_ENABLED=false
WORKER_METRICS_HOST=0.0.0.0
WORKER_METRICS_PORT=9091

TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

# Optional worker toggles (worker container is behind the "worker" profile)
OUTBOX_ENABLED=false
FEED_PROJECTION_WORKER_ENABLED=false

